:root {
  --green:        #1e5c2e;
  --green-mid:    #2a7a3e;
  --green-light:  #3a9950;
  --green-pale:   #e8f2eb;
  --cream:        #f7f4ed;
  --cream-dark:   #ede9df;
  --ink:          #141a14;
  --ink-soft:     #3d4d3d;
  --ink-muted:    #7a8a7a;
  --border:       #d8d2c4;
  --white:        #ffffff;
  --nav-h:        80px;
}

html { scroll-behavior: smooth; }
body {
  font-family: 'DM Sans', sans-serif;
  background: var(--cream);
  color: var(--ink);
  font-size: 16px;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

.jk-logo-mark { display:inline-flex; align-items:center; justify-content:center; flex-shrink:0; }
.jk-logo-mark svg { width:100%; height:100%; }

/* NAV */
nav {
  position:fixed; top:0; left:0; right:0; z-index:100;
  height:var(--nav-h);
  display:flex; align-items:center; justify-content:space-between;
  padding:0 56px;
  background:rgba(247,244,237,0.97);
  backdrop-filter:blur(14px);
  border-bottom:1px solid var(--border);
  transition:box-shadow .3s;
}
nav.scrolled { box-shadow:0 2px 28px rgba(30,92,46,.08); }

.nav-logo { display:flex; align-items:center; gap:12px; text-decoration:none; }
.nav-logo-text {
  font-family:'Cormorant Garamond',serif;
  font-size:19px; font-weight:500; letter-spacing:.05em;
  color:var(--ink); line-height:1.15;
}
.nav-logo-text span {
  display:block; font-size:10px; font-weight:400;
  letter-spacing:.14em; text-transform:uppercase; color:var(--green);
  font-family:'DM Sans',sans-serif;
}

.nav-links { display:flex; align-items:center; gap:36px; list-style:none; }
.nav-links a {
  font-size:12px; font-weight:400; letter-spacing:.08em;
  text-transform:uppercase; color:var(--ink-soft);
  text-decoration:none; transition:color .2s;
}
.nav-links a:hover { color:var(--green); }

.nav-actions { display:flex; gap:10px; align-items:center; }
.btn-ghost {
  font-size:11px; font-weight:500; letter-spacing:.08em;
  text-transform:uppercase; color:var(--ink);
  border:1px solid var(--border); border-radius:2px;
  padding:9px 18px; text-decoration:none;
  transition:all .2s; background:transparent;
}
.btn-ghost:hover { border-color:var(--green); color:var(--green); }
.btn-primary {
  font-size:11px; font-weight:500; letter-spacing:.08em;
  text-transform:uppercase; color:var(--white);
  background:var(--green); border:1px solid var(--green);
  border-radius:2px; padding:9px 22px;
  text-decoration:none; transition:background .2s;
}
.btn-primary:hover { background:var(--green-mid); }

/* HERO */
.hero {
  min-height:100vh;
  display:grid; grid-template-columns:1fr 1fr;
  padding-top:var(--nav-h);
}
.hero-left {
  display:flex; flex-direction:column; justify-content:center;
  padding:80px 64px 80px 80px;
  background:var(--cream);
  position:relative; overflow:hidden;
}
.hero-left::before {
  content:''; position:absolute; top:-80px; left:-80px;
  width:380px; height:380px;
  border:1px solid rgba(30,92,46,.12); border-radius:50%;
}
.hero-left::after {
  content:''; position:absolute; bottom:20px; right:-100px;
  width:260px; height:260px;
  border:1px solid rgba(30,92,46,.07); border-radius:50%;
}

.hero-eyebrow {
  font-size:11px; font-weight:500; letter-spacing:.16em;
  text-transform:uppercase; color:var(--green); margin-bottom:24px;
}
.hero-title {
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(40px,4.5vw,60px);
  font-weight:300; line-height:1.15;
  color:var(--ink); margin-bottom:24px;
}
.hero-title em { font-style:italic; color:var(--green); }
.hero-sub {
  font-size:15px; line-height:1.8; color:var(--ink-soft);
  max-width:420px; margin-bottom:40px;
}
.hero-ctas { display:flex; gap:14px; flex-wrap:wrap; }
.hero-cta-primary {
  display:inline-flex; align-items:center; gap:8px;
  background:var(--green); color:var(--white);
  font-size:12px; font-weight:500; letter-spacing:.08em;
  text-transform:uppercase; text-decoration:none;
  padding:14px 28px; border-radius:2px; transition:background .2s;
}
.hero-cta-primary:hover { background:var(--green-mid); }
.hero-cta-secondary {
  display:inline-flex; align-items:center; gap:8px;
  color:var(--ink); font-size:12px; font-weight:500;
  letter-spacing:.08em; text-transform:uppercase;
  text-decoration:none; border-bottom:1px solid var(--border);
  padding-bottom:2px; transition:border-color .2s,color .2s;
}
.hero-cta-secondary:hover { color:var(--green); border-color:var(--green); }

.hero-right { position:relative; overflow:hidden; background:var(--green); }
.hero-bg-jk {
  position:absolute; inset:0;
  display:flex; align-items:center; justify-content:center; opacity:.08;
}
.hero-bg-jk svg { width:72%; height:72%; }

.hero-stats {
  position:absolute; bottom:48px; left:40px; right:40px;
  display:grid; grid-template-columns:repeat(3,1fr);
  gap:1px; background:rgba(255,255,255,.15);
  border:1px solid rgba(255,255,255,.18); border-radius:2px;
}
.hero-stat {
  padding:22px 18px;
  background:rgba(20,26,20,.55);
  backdrop-filter:blur(10px);
}
.hero-stat-num {
  font-family:'Cormorant Garamond',serif;
  font-size:28px; font-weight:300; color:rgba(255,255,255,.92); line-height:1;
}
.hero-stat-label {
  font-size:10px; color:rgba(255,255,255,.45);
  letter-spacing:.08em; text-transform:uppercase; margin-top:6px;
}

/* SECTIONS */
section { padding:96px 80px; }
.section-eyebrow {
  font-size:11px; font-weight:500; letter-spacing:.15em;
  text-transform:uppercase; color:var(--green); margin-bottom:16px;
}
.section-title {
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(30px,3.5vw,46px); font-weight:300;
  line-height:1.2; color:var(--ink); margin-bottom:20px;
}
.section-title em { font-style:italic; }
.section-body { font-size:15px; line-height:1.8; color:var(--ink-soft); max-width:540px; }
.divider { width:44px; height:2px; background:var(--green-light); margin:22px 0; }

/* ABOUT */
.about {
  background:var(--white);
  display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center;
}
.about-cards { display:grid; gap:2px; }
.about-card {
  padding:28px 30px; background:var(--cream);
  border-left:2px solid transparent; transition:border-color .25s,background .25s;
}
.about-card:hover { border-color:var(--green); background:var(--white); }
.about-card h3 {
  font-family:'Cormorant Garamond',serif;
  font-size:20px; font-weight:500; margin-bottom:10px;
}
.about-card p { font-size:14px; line-height:1.7; color:var(--ink-soft); }

/* VALUES */
.values {
  background:var(--green); padding:48px 80px;
  display:flex; align-items:center; justify-content:space-between; gap:40px;
}
.values-tagline {
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(22px,2.5vw,32px); font-weight:300; font-style:italic;
  color:var(--white); max-width:460px; line-height:1.4;
}
.values-items { display:flex; gap:44px; flex-shrink:0; }
.value-item {
  font-size:11px; font-weight:500; letter-spacing:.12em;
  text-transform:uppercase; color:rgba(255,255,255,.65);
}

/* SERVICES */
.services { background:var(--ink); }
.services .section-eyebrow { color:var(--green-light); }
.services .section-title { color:var(--white); }
.services .section-body { color:rgba(255,255,255,.5); }
.services .divider { background:var(--green-light); }
.services-grid {
  display:grid; grid-template-columns:repeat(4,1fr);
  gap:2px; margin-top:56px;
}
.service-card {
  padding:32px 24px;
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.07);
  transition:background .25s,border-color .25s;
}
.service-card:hover { background:rgba(30,92,46,.2); border-color:rgba(58,153,80,.35); }
.service-icon { width:32px; height:32px; margin-bottom:18px; color:var(--green-light); }
.service-card h3 {
  font-family:'Cormorant Garamond',serif;
  font-size:18px; font-weight:500; color:var(--white);
  margin-bottom:10px; line-height:1.3;
}
.service-card p { font-size:13px; line-height:1.7; color:rgba(255,255,255,.42); }

/* TEAM */
.team { background:var(--cream); }
.team-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:20px; margin-top:52px; }
.team-card {
  background:var(--white); overflow:hidden;
  transition:transform .25s,box-shadow .25s;
}
.team-card:hover { transform:translateY(-4px); box-shadow:0 16px 40px rgba(30,92,46,.1); }
.team-photo-wrap {
  aspect-ratio:3/4; overflow:hidden; background:var(--green-pale);
  display:flex; align-items:center; justify-content:center;
}
.team-photo-wrap svg { width:100%; height:100%; }
.team-info { padding:20px 22px 24px; }
.team-name { font-family:'Cormorant Garamond',serif; font-size:20px; font-weight:500; margin-bottom:4px; }
.team-creds { font-size:11px; color:var(--green); font-weight:500; letter-spacing:.07em; margin-bottom:10px; text-transform:uppercase; }
.team-bio { font-size:13px; line-height:1.65; color:var(--ink-soft); }

/* CTA */
.cta-band {
  background:var(--cream-dark); padding:80px;
  display:flex; align-items:center; justify-content:space-between; gap:40px;
  border-top:1px solid var(--border);
}
.cta-band-actions { display:flex; gap:14px; flex-shrink:0; }
.btn-dark {
  font-size:12px; font-weight:500; letter-spacing:.08em;
  text-transform:uppercase; color:var(--white);
  background:var(--ink); border:1px solid var(--ink);
  padding:14px 28px; text-decoration:none; border-radius:2px; transition:background .2s;
}
.btn-dark:hover { background:var(--green); border-color:var(--green); }

/* FOOTER */
footer { background:var(--ink); color:rgba(255,255,255,.45); padding:56px 80px 36px; }
.footer-top {
  display:grid; grid-template-columns:2fr 1fr 1fr 1fr;
  gap:48px; padding-bottom:48px; border-bottom:1px solid rgba(255,255,255,.09);
}
.footer-brand p { font-size:13px; line-height:1.7; max-width:260px; margin-top:16px; }
.footer-col h4 {
  font-size:11px; font-weight:500; letter-spacing:.12em;
  text-transform:uppercase; color:rgba(255,255,255,.75); margin-bottom:16px;
}
.footer-col ul { list-style:none; }
.footer-col li { margin-bottom:10px; }
.footer-col a { font-size:13px; color:rgba(255,255,255,.38); text-decoration:none; transition:color .2s; }
.footer-col a:hover { color:var(--green-light); }
.footer-bottom {
  display:flex; justify-content:space-between; align-items:center;
  padding-top:28px; font-size:12px;
}
.footer-bottom a { color:rgba(255,255,255,.28); text-decoration:none; }
.footer-bottom a:hover { color:var(--green-light); }

/* ANIMATIONS */
.fade-up { opacity:0; transform:translateY(24px); transition:opacity .65s ease,transform .65s ease; }
.fade-up.visible { opacity:1; transform:none; }

/* RESPONSIVE */
@media(max-width:1100px){
  nav{padding:0 28px;} .nav-links{gap:22px;}
  section{padding:72px 40px;}
  .hero{grid-template-columns:1fr;min-height:auto;}
  .hero-left{padding:80px 40px;} .hero-right{height:420px;}
  .about{grid-template-columns:1fr;gap:40px;}
  .services-grid{grid-template-columns:repeat(2,1fr);}
  .team-grid{grid-template-columns:repeat(2,1fr);}
  .values{flex-direction:column;align-items:flex-start;}
  .cta-band{flex-direction:column;}
  .footer-top{grid-template-columns:1fr 1fr;gap:32px;}
}
@media(max-width:680px){
  nav{padding:0 20px;}
  .nav-links,.nav-actions .btn-ghost{display:none;}
  section{padding:56px 24px;}
  .hero-left{padding:60px 24px;}
  .services-grid{grid-template-columns:1fr;}
  .team-grid{grid-template-columns:1fr 1fr;}
  .values{padding:40px 24px;} .values-items{flex-wrap:wrap;gap:20px;}
  .cta-band{padding:56px 24px;}
  footer{padding:40px 24px 28px;} .footer-top{grid-template-columns:1fr;}
}
